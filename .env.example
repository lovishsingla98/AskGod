# Server-side only. Do not prefix this with VITE_.
GEMINI_API_KEY=
# Optional
GEMINI_MODEL=gemini-2.5-flash
# Cloudflare Rate Limiting binding (configured in the dashboard/wrangler, not as a secret):
# AI_RATE_LIMITER

# Client-side analytics (the project token is safe to expose in a Vite client bundle).
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=
